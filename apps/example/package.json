{
  "name": "@temporal-flow/example",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist && node ../scripts/generate-post-pdfs.mjs --app .",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "tsc --noEmit --isolatedDeclarations",
    "new-post": "node scripts/new-post.js",
    "format": "biome format --write ./src",
    "lint": "biome check --apply ./src",
    "preinstall": "npx only-allow pnpm",
    "game:dev": "astro dev --port 3001",
    "game:build": "astro build",
    "game:preview": "astro preview",
    "docs:generate": "typedoc --options typedoc.json"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.1.0",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/svelte": "7.0.3",
    "@astrojs/tailwind": "^5.1.5",
    "@fontsource-variable/jetbrains-mono": "^5.1.2",
    "@fontsource/roboto": "^5.1.1",
    "@fontsource/sriracha": "^5.1.1",
    "@iconify-json/fa6-brands": "^1.2.5",
    "@iconify-json/fa6-regular": "^1.2.3",
    "@iconify-json/fa6-solid": "^1.2.3",
    "@iconify-json/material-symbols": "^1.2.14",
    "@iconify-json/mdi": "^1.2.3",
    "@temporal-flow/blog-core": "workspace:*",
    "@iconify/svelte": "^5.0.0",
    "@swup/astro": "^1.5.0",
    "@tailwindcss/typography": "^0.5.16",
    "astro": "5.1.6",
    "astro-compress": "^2.3.6",
    "astro-icon": "^1.1.5",
    "astro-seo": "^0.8.4",
    "hastscript": "^9.0.0",
    "katex": "^0.16.21",
    "mammoth": "^1.9.0",
    "markdown-it": "^14.1.0",
    "marked": "^15.0.7",
    "mdast-util-to-string": "^4.0.0",
    "overlayscrollbars": "^2.10.1",
    "pagefind": "^1.3.0",
    "photoswipe": "^5.4.4",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-components": "^0.3.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^3.0.1",
    "remark-directive-rehype": "^0.4.2",
    "remark-github-admonitions-to-directives": "^1.0.5",
    "remark-math": "^6.0.0",
    "remark-sectionize": "^2.1.0",
    "sanitize-html": "^2.14.0",
    "sharp": "^0.33.5",
    "stylus": "^0.63.0",
    "svelte": "5.26.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.4",
    "@biomejs/biome": "1.8.3",
    "@types/markdown-it": "^14.1.2",
    "@types/mdast": "^4.0.4",
    "@types/sanitize-html": "^2.13.0",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.1",
