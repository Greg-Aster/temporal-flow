---
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('posts')

  return posts
    .filter(post => post.data.downloadable === true && post.data.draft !== true)
    .map(post => ({
      params: { slug: post.slug },
      props: { post },
    }))
}

const { post } = Astro.props
const { Content } = await post.render()

const publishedDate =
  post.data.published instanceof Date
    ? post.data.published.toISOString().slice(0, 10)
    : String(post.data.published)
---
<html lang={post.data.lang || 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title} - PDF</title>
    <style>
      @page {
        size: Letter;
        margin: 16mm;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        color: #101010;
        background: #fff;
        font-family: Georgia, 'Times New Roman', serif;
        line-height: 1.45;
      }

      .pdf-article {
        max-width: 7in;
        margin: 0 auto;
      }

      h1,
      h2,
      h3,
      h4 {
        page-break-after: avoid;
        break-after: avoid-page;
      }

      h1 {
        font-size: 2rem;
        line-height: 1.2;
        margin: 0 0 0.6rem;
      }

      h2 {
        font-size: 1.35rem;
        margin: 1.2rem 0 0.5rem;
      }

      p,
      li,
      table {
        font-size: 12pt;
      }

      .meta {
        margin: 0 0 0.75rem;
        color: #5b5b5b;
        font-size: 10pt;
      }

      .description {
        margin: 0 0 1rem;
        color: #333;
      }

      img {
        max-width: 100%;
        height: auto;
        border-radius: 6px;
        page-break-inside: avoid;
        break-inside: avoid;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin: 0.8rem 0;
      }

      th,
      td {
        border: 1px solid #ddd;
        padding: 0.4rem;
        vertical-align: top;
      }

      code,
      pre {
        font-family: 'JetBrains Mono', 'Courier New', monospace;
        font-size: 10pt;
      }

      pre {
        white-space: pre-wrap;
      }

      a {
        color: #0b5fff;
        text-decoration: underline;
      }

      hr {
        border: 0;
        border-top: 1px solid #ddd;
        margin: 1rem 0;
      }
    </style>
  </head>
  <body>
    <article class="pdf-article">
      <h1>{post.data.title}</h1>
      <p class="meta">Published: {publishedDate}</p>
      {post.data.description && <p class="description">{post.data.description}</p>}
      {post.data.image && post.data.showImageOnPost !== false && (
        <img src={post.data.image} alt={post.data.title} loading="eager" />
      )}
      <Content />
    </article>
  </body>
</html>
