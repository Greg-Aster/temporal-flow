---
import { getCollection } from 'astro:content'
import { formatDate, getRelativeTime } from '../../utils/date-utils'
import { parseJournalContent } from '../../utils/journal-utils'
import WidgetLayout from './WidgetLayout.astro'

interface Props {
  collection?: string
  slug?: string
  class?: string
  journalUrl?: string
  journalLinkLabel?: string
  excerptLength?: number
}

const {
  collection = 'updates',
  slug = 'sidebar-updates',
  journalUrl = '/journal/',
  journalLinkLabel = 'View full journal',
  excerptLength = 1000,
} = Astro.props
const className = Astro.props.class

const collectionEntries = await getCollection(collection as any)
const sourceEntry = collectionEntries.find((entry: any) => entry.slug === slug)

const current = sourceEntry?.data?.current
const journalContent = sourceEntry
  ? await parseJournalContent(sourceEntry.body, sourceEntry.data.entries ?? [], {
      excerptLength,
    })
  : null
const journalEntries = journalContent?.entries ?? []
const latestEntry = journalEntries[0]
---

{sourceEntry && (
  <div class:list={['flex flex-col gap-4', className]}>
    {current && (
      <WidgetLayout
        id={`${slug}-status`}
        class="onload-animation"
      >
        <div class="flex flex-col gap-3 pb-1">
          <div class="updates-summary-card">
            {current.status && (
              <div class="updates-summary-status">
                <span class="updates-label">Status</span>
                <span class="updates-value">{current.status}</span>
              </div>
            )}

            <div class="updates-summary-grid">
              {current.location && (
                <div class="updates-summary-row">
                  <span class="updates-label">Location</span>
                  <span class="updates-value">{current.location}</span>
                </div>
              )}
              {current.section && (
                <div class="updates-summary-row">
                  <span class="updates-label">Section</span>
                  <span class="updates-value">{current.section}</span>
                </div>
              )}
              {current.mileage && (
                <div class="updates-summary-row">
                  <span class="updates-label">Mileage</span>
                  <span class="updates-value">{current.mileage}</span>
                </div>
              )}
              {current.nextStop && (
                <div class="updates-summary-row">
                  <span class="updates-label">Next</span>
                  <span class="updates-value">{current.nextStop}</span>
                </div>
              )}
              {current.updated && (
                <div class="updates-summary-row">
                  <span class="updates-label">Updated</span>
                  <span class="updates-value">
                    {formatDate(current.updated)}
                    <span class="updates-meta">({getRelativeTime(current.updated)})</span>
                  </span>
                </div>
              )}
            </div>
          </div>

          {latestEntry ? (
            <div class="updates-journal-preview">
              <div class="updates-journal-preview-header">
                <span class="updates-label">
                  {sourceEntry.data.journalTitle || 'Journal'}
                </span>
                <span class="text-xs text-black/40 dark:text-white/40">
                  {formatDate(latestEntry.date)}
                </span>
              </div>
              {latestEntry.title && (
                <div class="text-sm font-semibold text-black/85 dark:text-white/85">
                  {latestEntry.title}
                </div>
              )}
              {(latestEntry.location || latestEntry.mileage) && (
                <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-black/50 dark:text-white/50">
                  {latestEntry.location && <span>{latestEntry.location}</span>}
                  {latestEntry.mileage && <span>{latestEntry.mileage}</span>}
                </div>
              )}
              <p class="text-sm leading-6 text-black/70 dark:text-white/70">
                {latestEntry.excerpt}
              </p>
            </div>
          ) : current.note && (
            <p class="text-sm leading-6 text-black/70 dark:text-white/70 whitespace-pre-line">
              {current.note}
            </p>
          )}

          {journalContent?.introHtml && (
            <div class="updates-body text-sm leading-6 text-black/70 dark:text-white/70">
              <div set:html={journalContent.introHtml} />
            </div>
          )}
          <a
            href={journalUrl}
            class="updates-journal-link btn-card mt-1 rounded-2xl px-4 py-3 flex items-center justify-between gap-3 active:scale-95"
          >
            <div class="overflow-hidden">
              <div class="text-[0.72rem] uppercase tracking-[0.08em] text-black/45 dark:text-white/45">
                Trail Journal
              </div>
              <div class="text-sm font-semibold text-black/80 dark:text-white/80">
                {journalLinkLabel}
              </div>
            </div>
            <div class="text-[var(--primary)] text-xl leading-none">→</div>
          </a>
        </div>
      </WidgetLayout>
    )}
  </div>
)}

<style>
  .updates-summary-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    border-radius: 1rem;
    background: rgb(0 0 0 / 0.03);
    border: 1px solid rgb(0 0 0 / 0.08);
  }

  .updates-summary-status {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px dashed rgb(0 0 0 / 0.1);
  }

  .updates-summary-grid {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .updates-summary-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.4rem 0.75rem;
    align-items: baseline;
  }

  .updates-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(0 0 0 / 0.45);
  }

  .updates-value {
    font-size: 0.95rem;
    color: rgb(0 0 0 / 0.78);
  }

  .updates-meta {
    color: rgb(0 0 0 / 0.45);
    margin-left: 0.25rem;
    font-size: 0.8rem;
  }

  .updates-body :global(p + p) {
    margin-top: 0.75rem;
  }

  .updates-journal-preview {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 0.1rem;
  }

  .updates-journal-preview-header {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: baseline;
  }

  :global(.dark) .updates-summary-card {
    background: rgb(255 255 255 / 0.04);
    border-color: rgb(255 255 255 / 0.1);
  }

  :global(.dark) .updates-summary-status {
    border-bottom-color: rgb(255 255 255 / 0.12);
  }

  :global(.dark) .updates-label {
    color: rgb(255 255 255 / 0.45);
  }

  :global(.dark) .updates-value {
    color: rgb(255 255 255 / 0.8);
  }

  :global(.dark) .updates-meta {
    color: rgb(255 255 255 / 0.45);
  }
</style>
