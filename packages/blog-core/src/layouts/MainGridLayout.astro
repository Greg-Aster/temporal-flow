      height: var(--banner-height-mobile, var(--banner-height));
    }
  }

  .banner-media-layer {
    position: relative;
    overflow: hidden;
  }

  .banner-media-layer > .banner-image,
  .banner-media-layer > .banner-video,
  .banner-media-layer > .banner-image-fallback {
    transform-origin: center center;
    will-change: transform;
  }

  .banner-media-layer.banner-motion-active > .banner-image,
  .banner-media-layer.banner-motion-active > .banner-video,
  .banner-media-layer.banner-motion-active > .banner-image-fallback {
    animation-duration: var(--banner-motion-duration, 6000ms);
    animation-timing-function: var(--banner-motion-easing, ease-in-out);
    animation-fill-mode: both;
    animation-iteration-count: 1;
  }

  .banner-media-layer.banner-motion-zoom-in > .banner-image,
  .banner-media-layer.banner-motion-zoom-in > .banner-video,
  .banner-media-layer.banner-motion-zoom-in > .banner-image-fallback {
    animation-name: bannerMotionZoomIn;
  }

  .banner-media-layer.banner-motion-zoom-out > .banner-image,
  .banner-media-layer.banner-motion-zoom-out > .banner-video,
  .banner-media-layer.banner-motion-zoom-out > .banner-image-fallback {
    animation-name: bannerMotionZoomOut;
  }

  .banner-media-layer.banner-motion-pan-left > .banner-image,
  .banner-media-layer.banner-motion-pan-left > .banner-video,
  .banner-media-layer.banner-motion-pan-left > .banner-image-fallback {
    animation-name: bannerMotionPanLeft;
  }

  .banner-media-layer.banner-motion-pan-right > .banner-image,
  .banner-media-layer.banner-motion-pan-right > .banner-video,
  .banner-media-layer.banner-motion-pan-right > .banner-image-fallback {
    animation-name: bannerMotionPanRight;
  }

  .banner-media-layer.banner-motion-pan-up > .banner-image,
  .banner-media-layer.banner-motion-pan-up > .banner-video,
  .banner-media-layer.banner-motion-pan-up > .banner-image-fallback {
    animation-name: bannerMotionPanUp;
  }

  .banner-media-layer.banner-motion-pan-down > .banner-image,
  .banner-media-layer.banner-motion-pan-down > .banner-video,
  .banner-media-layer.banner-motion-pan-down > .banner-image-fallback {
    animation-name: bannerMotionPanDown;
  }

  @keyframes bannerMotionZoomIn {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(var(--banner-motion-scale, 1.08));
    }
  }

  @keyframes bannerMotionZoomOut {
    from {
      transform: scale(var(--banner-motion-scale, 1.08));
    }
    to {
      transform: scale(1);
    }
  }

  @keyframes bannerMotionPanLeft {
    from {
      transform: scale(var(--banner-motion-pan-scale, 1.1))
        translate3d(0, 0, 0);
    }
    to {
      transform: scale(var(--banner-motion-pan-scale, 1.1))
        translate3d(calc(-1 * var(--banner-motion-pan-distance, 4%)), 0, 0);
    }
  }

  @keyframes bannerMotionPanRight {
    from {
      transform: scale(var(--banner-motion-pan-scale, 1.1))
        translate3d(calc(-1 * var(--banner-motion-pan-distance, 4%)), 0, 0);
    }
    to {
      transform: scale(var(--banner-motion-pan-scale, 1.1))
        translate3d(0, 0, 0);
    }
  }

  @keyframes bannerMotionPanUp {
    from {
      transform: scale(var(--banner-motion-pan-scale, 1.1))
        translate3d(0, 0, 0);
    }
    to {
      transform: scale(var(--banner-motion-pan-scale, 1.1))
        translate3d(0, calc(-1 * var(--banner-motion-pan-distance, 4%)), 0);
    }
  }

  @keyframes bannerMotionPanDown {
    from {
      transform: scale(var(--banner-motion-pan-scale, 1.1))
        translate3d(0, calc(-1 * var(--banner-motion-pan-distance, 4%)), 0);
    }
    to {
      transform: scale(var(--banner-motion-pan-scale, 1.1))
        translate3d(0, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .banner-media-layer.banner-motion-active > .banner-image,
    .banner-media-layer.banner-motion-active > .banner-video,
    .banner-media-layer.banner-motion-active > .banner-image-fallback {
      animation: none !important;
    }
  }
</style>

