    margin-top: var(--main-content-offset);
  }
  
  /* ⭐ ESSENTIAL: Main panel positioning */
  .responsive-panel-wrapper {
    top: var(--main-panel-top);
    transition: top 0.3s ease;
  }
  
  /* ⭐ ESSENTIAL: Banner spacing from navbar */
